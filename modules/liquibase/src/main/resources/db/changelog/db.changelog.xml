    <changeSet id="heph-person-add-account-columns" author="codex">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="heph_person"/>
            <not>
                <columnExists tableName="heph_person" columnName="username"/>
            </not>
        </preConditions>
        <addColumn tableName="heph_person">
            <column name="username" type="varchar(64)" defaultValue="">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="heph_person">
            <column name="password" type="varchar(128)" defaultValue="">
                <constraints nullable="false"/>
            </column>
        </addColumn>
