    <changeSet id="sys-config-definition-create-table" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="sys_config_definition"/>
            </not>
        </preConditions>
        <createTable tableName="sys_config_definition">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_sys_config_definition"/>
            </column>
            <column name="config_code" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="config_name" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="config_group" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="config_tab" type="varchar(64)" defaultValue="general">
                <constraints nullable="false"/>
            </column>
            <column name="section_code" type="varchar(64)" defaultValue="main-system">
                <constraints nullable="false"/>
            </column>
            <column name="section_name" type="varchar(128)" defaultValue="主系统配置">
                <constraints nullable="false"/>
            </column>
            <column name="component_type" type="varchar(32)" defaultValue="text">
                <constraints nullable="false"/>
            </column>
            <column name="default_value" type="text"/>
            <column name="options_json" type="text"/>
            <column name="placeholder_text" type="varchar(255)"/>
            <column name="help_text" type="varchar(512)"/>
            <column name="required_flag" type="tinyint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="public_flag" type="tinyint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="sensitive_flag" type="tinyint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="enabled_flag" type="tinyint" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addUniqueConstraint tableName="sys_config_definition"
                             columnNames="config_code"
                             constraintName="uk_sys_config_definition_code"/>
        <createIndex tableName="sys_config_definition" indexName="idx_sys_config_definition_group">
            <column name="config_group"/>
            <column name="enabled_flag"/>
            <column name="sort_order"/>
        </createIndex>
    </changeSet>

